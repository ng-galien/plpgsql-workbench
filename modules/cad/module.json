{
  "name": "cad",
  "version": "0.1.0",
  "description": "CAD 3D engine for wood structures. PostGIS/SFCGAL geometry, Three.js viewer, wireframe rendering, bill of materials.",
  "schemas": {
    "public": "cad",
    "private": "_cad",
    "qa": "cad_qa"
  },
  "dependencies": [
    "pgv"
  ],
  "extensions": [
    "postgis",
    "postgis_sfcgal"
  ],
  "sql": [
    "build/cad.ddl.sql",
    "build/cad.func.sql"
  ],
  "assets": {
    "frontend": [],
    "scripts": [
      "frontend/three.min.js",
      "frontend/cad.js"
    ],
    "styles": [
      "frontend/cad.css"
    ]
  },
  "grants": {
    "anon": ["cad"]
  },
  "docker": {
    "image": "postgis/postgis:17-3.5",
    "note": "Requires PostGIS image (not supabase/postgres)"
  }
}
