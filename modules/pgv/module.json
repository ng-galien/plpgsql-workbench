{
  "name": "pgv",
  "version": "1.0.0",
  "description": "pgView — PostgreSQL SDUI foundation: api dispatcher, view contract, i18n, introspection and UI primitives.",
  "schemas": {
    "public": "pgv",
    "private": null,
    "qa": "pgv_qa"
  },
  "dependencies": [],
  "extensions": [
    "plpgsql_check",
    "pgtap",
    "unaccent"
  ],
  "sql": [
    "build/pgv.ddl.sql",
    "build/pgv_qa.ddl.sql",
    "build/pgv.func.sql",
    "build/pgv_qa.func.sql",
    "build/pgv_ut.func.sql"
  ],
  "assets": {
    "frontend": [
      "frontend/index.html",
      "frontend/pgview.css"
    ]
  },
  "grants": {
    "anon": [
      "pgv",
      "pgv_ut",
      "pgv_qa"
    ]
  }
}
