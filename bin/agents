#!/usr/bin/env bash
# Idempotent agent spawner — one tmux session per module
# Usage: bin/agents [module...]
#   bin/agents          → spawn all modules
#   bin/agents crm pgv  → spawn only crm and pgv

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MODULES_DIR="$ROOT/modules"

# Claude env vars to strip (avoid nesting)
STRIP_VARS="CLAUDECODE CLAUDE_CODE_ENTRYPOINT CLAUDE_CODE_SESSION_ID"
STRIP_VARS="$STRIP_VARS CLAUDE_CODE_CONVERSATION_ID CLAUDE_CODE_TASK_ID"
STRIP_VARS="$STRIP_VARS NON_INTERACTIVE MCP_TRANSPORT MCP_SESSION_ID"

# Determine which modules to spawn
if [ $# -gt 0 ]; then
  MODULES=("$@")
else
  MODULES=()
  for d in "$MODULES_DIR"/*/; do
    [ -d "$d" ] && MODULES+=("$(basename "$d")")
  done
fi

spawned=0
skipped=0
errors=0

for mod in "${MODULES[@]}"; do
  mod_path="$MODULES_DIR/$mod"
  if [ ! -d "$mod_path" ]; then
    echo "  SKIP  $mod (not found)"
    ((errors++)) || true
    continue
  fi

  # Idempotent: skip if session already exists
  if tmux has-session -t "$mod" 2>/dev/null; then
    echo "  OK    $mod (already running)"
    ((skipped++)) || true
    continue
  fi

  # Write spawn script
  spawn_script="/tmp/pgw-spawn-${mod}.sh"
  cat > "$spawn_script" <<SPAWN
#!/bin/sh
unset $STRIP_VARS
exec claude
SPAWN
  chmod 700 "$spawn_script"

  # Spawn tmux session
  tmux new-session -d -s "$mod" -c "$mod_path" "$spawn_script"
  tmux set-option -t "$mod" history-limit 50000 2>/dev/null
  tmux set-option -t "$mod" remain-on-exit on 2>/dev/null

  echo "  START $mod (pid $(tmux list-panes -t "$mod" -F '#{pane_pid}'))"
  ((spawned++)) || true
done

echo ""
echo "Done: $spawned started, $skipped already running, $errors errors"
echo "Monitor: curl http://localhost:3100/api/tmux"
