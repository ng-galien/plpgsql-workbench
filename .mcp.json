{
  "mcpServers": {
    "plpgsql-workbench": {
      "type": "http",
      "url": "http://localhost:3100/mcp"
    },
    "maket": {
      "type": "http",
      "url": "http://localhost:3337/mcp",
      "headers": { "X-Session": "lead" }
    },
    "workbench-msg": {
      "command": "npx",
      "args": ["tsx", "src/channel/workbench-msg.ts"],
      "env": {
        "MODULE": "lead"
      }
    }
  }
}
