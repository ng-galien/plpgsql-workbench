{
  "name": "plpgsql-mcp",
  "version": "0.1.0",
  "description": "MCP server for PL/pgSQL Workbench",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "plpgsql-mcp": "dist/index.js",
    "pgm": "dist/core/pgm/cli.js",
    "plx": "dist/core/plx/cli.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage:plx": "vitest run src/core/plx/__tests__ --coverage",
    "coverage": "vitest run --coverage",
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node dist/index.js",
    "predev": "lsof -ti:3100 | xargs kill -9 2>/dev/null || true",
    "dev": "WORKBENCH_MODE=dev PLPGSQL_CONNECTION=postgresql://postgres:postgres@localhost:54322/postgres nodemon --watch src --ext ts --exec 'node --import tsx src/index.ts' & cd app && npx vite",
    "dev:uxlab": "WORKBENCH_MODE=dev WORKBENCH_CONFIG=apps/001-uxlab/workbench.json nodemon --watch src --ext ts --exec 'node --import tsx src/index.ts'",
    "dev:demo": "WORKBENCH_MODE=dev WORKBENCH_CONFIG=apps/002-demo/workbench.json nodemon --watch src --ext ts --exec 'node --import tsx src/index.ts'",
    "dev:docman": "WORKBENCH_MODE=dev WORKBENCH_CONFIG=apps/003-docman/workbench.json nodemon --watch src --ext ts --exec 'node --import tsx src/index.ts'",
    "sync-tools": "PLPGSQL_CONNECTION=postgresql://postgres:postgres@localhost:54322/postgres node --import tsx src/sync-tools.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@libpg-query/parser": "^17.6.3",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@supabase/supabase-js": "^2.99.1",
    "awilix": "^13.0.3",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "node-pty": "^1.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "lefthook": "^2.1.4",
    "nodemon": "^3.1.14",
    "playwright": "^1.58.2",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "testcontainers": "^11.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
